package main

import (
	"embed"
	"fmt"
	"io/fs"
	"net/http"
	"os"
	"strings"
	"time"

	"{{.ModulePath}}/src"
	"github.com/ecocee/golang-ui/pkg/api"
	"github.com/webview/webview_go"
)

//go:embed all:frontend/out
var assets embed.FS

// serveFallback serves the static Next.js export, mapping clean paths to their
// .html files and falling back to index.html otherwise.
func serveFallback(subFS fs.FS) http.Handler {
	fsSrv := http.FileServer(http.FS(subFS))
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		path := strings.TrimPrefix(r.URL.Path, "/")
		if path == "" {
			path = "index.html"
		} else if !strings.HasSuffix(path, ".html") {
			path = path + ".html"
		}

		_, err := fs.Stat(subFS, path)
		if os.IsNotExist(err) {
			r.URL.Path = "/"
		} else {
			r.URL.Path = "/" + path
		}
		fsSrv.ServeHTTP(w, r)
	})
}

func main() {
	isDev := os.Getenv("GLYRA_DEV") == "true"
	w := webview.New(isDev)
	defer w.Destroy()

	w.SetTitle("{{.Title}}")
	w.SetSize(900, 650, webview.HintNone)

	// Register backend services into the API Bridge. Add your own services
	// under src/ and register them here, e.g.
	//   registry.Register("Auth", &src.AuthService{})
	registry := api.NewRegistry(w)
	registry.Register("System", &src.SystemService{})

	if isDev {
		// Generate the TypeScript bindings on startup during dev mode so the
		// frontend gets typed window.System_* calls.
		registry.GenerateTS("frontend/src/api.ts")
		w.Navigate("http://localhost:3000")
		fmt.Println("Glyra Backend started in DEV mode.")
	} else {
		subFS, _ := fs.Sub(assets, "out")
		go func() {
			http.Handle("/", serveFallback(subFS))
			http.ListenAndServe("127.0.0.1:8080", nil)
		}()
		time.Sleep(100 * time.Millisecond)
		w.Navigate("http://127.0.0.1:8080")
		fmt.Println("Glyra Backend started in PROD mode.")
	}

	w.Run()
}
