package main

import (
	"embed"
	"flag"
	"io/fs"
	"net/http"
	"time"

	"{{.ModulePath}}/src"
	"github.com/ecocee/golang-ui/pkg/api"
	"github.com/webview/webview_go"
)

// In dev mode the app connects to the Vite dev server (npm run dev) for
// hot reload. In production the built frontend (frontend/dist, produced
// by `npm run build`) is embedded directly into the binary, so the
// compiled app is a single portable file.
//
//go:embed all:frontend/dist
var distFS embed.FS

func main() {
	dev := flag.Bool("dev", false, "connect to the Vite dev server instead of the embedded build")
	flag.Parse()

	w := webview.New(true)
	defer w.Destroy()

	w.SetTitle("{{.Title}}")
	w.SetSize(900, 650, webview.HintNone)

	// Register backend services into the API Bridge. Add your own services
	// under src/ and register them here, e.g.
	//   registry.Register("Auth", &src.AuthService{})
	registry := api.NewRegistry(w)
	registry.Register("System", &src.SystemService{})

	if *dev {
		w.Navigate("http://localhost:5173")
	} else {
		assets, err := fs.Sub(distFS, "dist")
		if err != nil {
			panic(err)
		}
		go func() {
			http.Handle("/", http.FileServer(http.FS(assets)))
			_ = http.ListenAndServe("127.0.0.1:8080", nil)
		}()
		time.Sleep(100 * time.Millisecond)
		w.Navigate("http://127.0.0.1:8080")
	}

	w.Run()
}
