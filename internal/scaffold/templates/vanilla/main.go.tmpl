package main

import (
	"embed"
	"io/fs"
	"net/http"
	"os"
	"time"

	"{{.ModulePath}}/src"
	"github.com/ecocee/golang-ui/pkg/api"
	"github.com/webview/webview_go"
)

// The frontend is embedded directly into the binary at build time, so the
// compiled app is a single portable file — no frontend/ folder needed
// alongside it at runtime.
//
//go:embed all:frontend
var frontendFS embed.FS

func main() {
	isDev := os.Getenv("GLYRA_DEV") == "true"

	w := webview.New(true)
	defer w.Destroy()

	w.SetTitle("{{.Title}}")
	w.SetSize(900, 650, webview.HintNone)

	// Register backend services into the API Bridge. Add your own services
	// under src/ and register them here, e.g.
	//   registry.Register("Auth", &src.AuthService{})
	registry := api.NewRegistry(w)
	registry.Register("System", &src.SystemService{})

	go func() {
		var assets http.FileSystem
		if isDev {
			assets = http.Dir("frontend")
		} else {
			sub, err := fs.Sub(frontendFS, "frontend")
			if err != nil {
				panic(err)
			}
			assets = http.FS(sub)
		}

		mux := http.NewServeMux()
		mux.Handle("/", http.FileServer(assets))
		if isDev {
			mux.HandleFunc("/__glyra_reload", func(res http.ResponseWriter, req *http.Request) {
				w.Dispatch(func() {
					w.Eval("window.location.reload(true);")
				})
				res.WriteHeader(200)
			})
		}
		_ = http.ListenAndServe("127.0.0.1:8080", mux)
	}()
	time.Sleep(100 * time.Millisecond) // give the local server a moment to bind

	w.Navigate("http://127.0.0.1:8080")
	w.Run()
}
