<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{.ProjectName}}</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="glass-card">
    <h1>{{.ProjectName}}</h1>
    <p>Go ↔ JS bridge demo — click a button to call into your Go backend.</p>

    <div class="bridge-status" id="bridgeStatus">
      <span class="dot" id="bridgeDot"></span>
      <span id="bridgeLabel">Connecting to Go…</span>
    </div>

    <div class="bridge-row">
      <div class="bridge-card">
        <div class="bridge-label">JS counter</div>
        <div class="bridge-value" id="jsCounter">0</div>
        <button id="jsCounterBtn" class="btn">Increment</button>
      </div>

      <div class="bridge-card">
        <div class="bridge-label">Go echo</div>
        <input type="text" id="echoInput" placeholder="type a message…" />
        <button id="echoBtn" class="btn">Send to Go</button>
        <div class="bridge-value" id="echoReply">—</div>
      </div>
    </div>

    <div class="bridge-card">
      <div class="bridge-label">GetSystemStatus (Go backend health)</div>
      <button id="pingButton" class="btn">Ping Go Backend</button>
      <div class="bridge-value" id="statusBox">Waiting…</div>
    </div>
  </div>

  <script src="app.js"></script>
</body>
</html>
